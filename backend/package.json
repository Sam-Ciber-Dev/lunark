{
  "name": "@lunark/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./app": {
      "import": "./dist/app.js",
      "types": "./dist/app.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup src/index.ts src/app.ts --format esm --dts --external @libsql/client",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "@libsql/client": "^0.17.2",
    "@lunark/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "drizzle-kit": "^0.31.1",
    "eslint": "^8",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5"
  }
}
